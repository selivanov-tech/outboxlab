# Local HTTPS reverse proxy.
# Hostnames come from API_DOMAIN / WEB_DOMAIN in .env (gitignored).
# Certs come from `make certs` (mkcert).

{
	auto_https off
}

{$API_DOMAIN} {
	tls /certs/local.pem /certs/local-key.pem
	reverse_proxy api:8000
}

{$WEB_DOMAIN} {
	tls /certs/local.pem /certs/local-key.pem
	reverse_proxy web:3000
}
