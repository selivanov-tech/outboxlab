# OutboxLab — local dev environment
# Copy to .env (`make env`). Never commit .env.

# ---- Local domains ----
# Real values live in .env only. Used by Caddy proxy + Makefile (certs, hosts).
# Pick anything you control, e.g. api.<project>.local or api.<project>.local.<your-domain>
API_DOMAIN=api.example.local
WEB_DOMAIN=app.example.local

# ---- Database ----
# DATABASE_URL: SQLAlchemy + asyncpg, used inside compose containers (`postgres` resolves via the compose network).
# DATABASE_URL_PSQL: plain libpq URL for host-side tools (psql, IDE) — libpq does not understand the `+asyncpg` dialect tag.
# Postgres is published on 127.0.0.1:55432 to avoid clashing with any other local pg.
# Production: Neon URL goes to fly secrets, NOT here.
DATABASE_URL=postgresql+asyncpg://outboxlab:outboxlab@postgres:5432/outboxlab
DATABASE_URL_PSQL=postgresql://outboxlab:outboxlab@127.0.0.1:55432/outboxlab
POSTGRES_USER=outboxlab
POSTGRES_PASSWORD=outboxlab
POSTGRES_DB=outboxlab

# ---- Google OAuth (Gmail API) ----
# The redirect URI is derived at runtime as `https://${API_DOMAIN}/auth/google/callback`
# — this is intentional, so the URL cannot drift away from API_DOMAIN. Register that
# exact URL (for each env: local mkcert, fly.dev, custom domain) in your GCP OAuth client
# under "Authorized redirect URIs".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- LLM (optional, step 2+) ----
# Pick one. Empty = deterministic fallback classifier.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- App ----
APP_ENV=local
LOG_LEVEL=info
API_PORT=8000
WEB_PORT=3000
